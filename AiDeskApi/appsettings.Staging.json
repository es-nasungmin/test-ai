{
  "Database": {
    "Provider": "mssql",
    "__comment": "운영 직전 검증 서버(Staging)에서는 mssql 사용"
  },
  "ConnectionStrings": {
    "AiDeskDb": "Server=STAGING_MSSQL_SERVER;Database=CrmStagingDb;User Id=STAGING_USER;Password=STAGING_PASSWORD;Encrypt=True;TrustServerCertificate=True;",
    "__comment": "Staging 서버 전용 MSSQL 연결 문자열"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://staging-admin.your-domain.com",
      "https://staging-user.your-domain.com"
    ]
  }
}